import pygame
import random

# --- CONFIGURAÇÕES ---
lagura_tela = 800
altura_tela = 500 
lado_quadrado = 20
fps = 12 # Aumentei um pouquinho a velocidade para ficar mais divertido

# Cores
COR_FUNDO = "#1A1A1D"       
COR_COBRA_CORPO = "#3498DB" 
COR_COBRA_BORDA = "#2980B9" 
COR_COMIDA = "#F1C40F"      

rodando = True
xq = lagura_tela // 2
yq = altura_tela // 2
move_x = 0
move_y = 0 

corpo_cobra = [] 
tamanho_cobra = 1

def gerar_comida():
    # Ajustado para garantir que a comida caia sempre dentro da grade
    x = random.randrange(0, lagura_tela, lado_quadrado)
    y = random.randrange(0, altura_tela, lado_quadrado)
    return x, y 

comida_x, comida_y = gerar_comida()

def reiniciar():
    global xq, yq, move_x, move_y, corpo_cobra, tamanho_cobra, comida_x, comida_y
    xq, yq = lagura_tela // 2, altura_tela // 2
    move_x, move_y = 0, 0
    corpo_cobra = []
    tamanho_cobra = 1
    comida_x, comida_y = gerar_comida()

def proc_eventos():
    global rodando, move_x, move_y
    for evento in pygame.event.get():
        if evento.type == pygame.QUIT:
            rodando = False

        if evento.type == pygame.KEYDOWN:
            # Bloqueia a volta imediata (não deixa a cobra virar 180° nela mesma)
            if evento.key == pygame.K_UP and move_y == 0:
                move_x = 0
                move_y = -lado_quadrado
            elif evento.key == pygame.K_DOWN and move_y == 0:
                move_x = 0
                move_y = lado_quadrado
            elif evento.key == pygame.K_LEFT and move_x == 0:
                move_y = 0
                move_x = -lado_quadrado
            elif evento.key == pygame.K_RIGHT and move_x == 0:
                move_y = 0
                move_x = lado_quadrado
            elif evento.key == pygame.K_ESCAPE:
                rodando = False

def atualizar_logica():
    global xq, yq, corpo_cobra, tamanho_cobra, comida_x, comida_y

    # 1. Movimentar a cabeça
    xq += move_x
    yq += move_y

    # 2. Checar colisão com as bordas
    if xq < 0 or xq >= lagura_tela or yq < 0 or yq >= altura_tela:
        reiniciar()
        return

    # 3. Checar se comeu a comida ANTES de mover o resto do corpo
    if xq == comida_x and yq == comida_y:
        tamanho_cobra += 1
        comida_x, comida_y = gerar_comida()

    # 4. Adicionar nova cabeça ao corpo
    cabeca_atual = [xq, yq]
    
    # Checar colisão com o próprio corpo
    if cabeca_atual in corpo_cobra:
        reiniciar()
        return

    corpo_cobra.append(cabeca_atual)

    # 5. Manter o tamanho correto (apaga o rabo se não cresceu)
    if len(corpo_cobra) > tamanho_cobra:
        del corpo_cobra[0]

def desenhar_placar(tela, pontuação):
    texto = f"Pontos: {pontuação - 1}" 
    imagem_texto = fonte.render(texto, True, "#FFFFFF")
    tela.blit(imagem_texto, (10, 10))

if __name__ == "__main__":
    pygame.init()
    tela = pygame.display.set_mode((lagura_tela, altura_tela))
    pygame.display.set_caption("Snake Game - Matheus")
    relogio = pygame.time.Clock()
    fonte = pygame.font.SysFont("Arial", 25, bold=True)

    while rodando:
        proc_eventos()

        if move_x != 0 or move_y != 0:
            atualizar_logica()

        # Desenho
        tela.fill(COR_FUNDO)

        # Desenha Comida
        pygame.draw.rect(tela, COR_COMIDA, (comida_x, comida_y, lado_quadrado, lado_quadrado))

        # Desenha Cobra
        for pedaco in corpo_cobra:
            pygame.draw.rect(tela, COR_COBRA_CORPO, (pedaco[0], pedaco[1], lado_quadrado, lado_quadrado))
            pygame.draw.rect(tela, COR_COBRA_BORDA, (pedaco[0], pedaco[1], lado_quadrado, lado_quadrado), 1)
        
        desenhar_placar(tela, tamanho_cobra)
        pygame.display.flip()
        relogio.tick(fps)

    pygame.quit()
