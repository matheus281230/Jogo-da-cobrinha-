import pygame
import random

# --- CONFIGURAÇÕES ---
lagura_tela = 800
altura_tela = 500  # Alterado para 500 conforme solicitado
lado_quadrado = 20
fps = 10

# Novas Cores (Hexadecimal)
COR_FUNDO = "#1A1A1D"       # Um cinza quase preto
COR_COBRA_CORPO = "#3498DB" # Azul vibrante
COR_COBRA_BORDA = "#2980B9" # Azul escuro para a borda
COR_COMIDA = "#F1C40F"      # Amarelo

rodando = True
xq = lagura_tela // 2
yq = altura_tela // 2
move_x = 0
move_y = 0 

corpo_cobra = [] 
tamanho_cobra = 1

def gerar_comida():
    x = random.randrange(0, lagura_tela - lado_quadrado, lado_quadrado)
    y = random.randrange(0, altura_tela - lado_quadrado, lado_quadrado)
    return x, y 

comida_x, comida_y = gerar_comida()

def reiniciar():
    global xq, yq, move_x, move_y, corpo_cobra, tamanho_cobra, comida_x, comida_y
    xq, yq = lagura_tela // 2, altura_tela // 2
    move_x, move_y = 0, 0
    corpo_cobra = []
    tamanho_cobra = 1
    comida_x, comida_y = gerar_comida()

def proc_eventos():
    global rodando, move_x, move_y
    for evento in pygame.event.get():
        if evento.type == pygame.QUIT:
            rodando = False

        if evento.type == pygame.KEYDOWN:
            if evento.key == pygame.K_UP and move_y == 0:
                move_x = 0
                move_y = -lado_quadrado
            if evento.key == pygame.K_DOWN and move_y == 0:
                move_x = 0
                move_y = lado_quadrado
            if evento.key == pygame.K_LEFT and move_x == 0:
                move_y = 0
                move_x = -lado_quadrado
            if evento.key == pygame.K_RIGHT and move_x == 0:
                move_y = 0
                move_x = lado_quadrado
            if evento.key == pygame.K_ESCAPE:
                rodando = False

def proc_colisoes():
    global xq, yq, corpo_cobra, comida_x, comida_y, tamanho_cobra

    # Colisão com as bordas
    if xq < 0 or xq >= lagura_tela or yq < 0 or yq >= altura_tela:
        reiniciar()

    # Colisão com o próprio corpo
    cabeca = [xq, yq]
    for pedaco in corpo_cobra[:-1]:
        if pedaco == cabeca:
            reiniciar()

    # Colisão com a comida
    if xq == comida_x and yq == comida_y:
        tamanho_cobra += 1 
        comida_x, comida_y = gerar_comida()

def atualizar_movimento():
    global xq, yq, corpo_cobra, tamanho_cobra
    xq += move_x
    yq += move_y

    cabeca_atual = [xq, yq]
    corpo_cobra.append(cabeca_atual)
    
    if len(corpo_cobra) > tamanho_cobra:
        del corpo_cobra[0]

def desenhar_placar(tela, pontuação):
    texto = f"Pontos: {pontuação - 1}" 
    imagem_texto = fonte.render(texto, True, "#FFFFFF")
    tela.blit(imagem_texto, (10, 10))

if __name__ == "__main__":
    pygame.init()
    tela = pygame.display.set_mode((lagura_tela, altura_tela))
    pygame.display.set_caption("Trabalho de Pygame - Matheus")
    relogio = pygame.time.Clock()
    fonte = pygame.font.SysFont("Arial", 25, bold=True)

    while rodando:
        proc_eventos()

        if move_x != 0 or move_y != 0:
            atualizar_movimento()
            proc_colisoes()

        # Desenho
        tela.fill(COR_FUNDO)

        # Desenha Comida
        pygame.draw.rect(tela, COR_COMIDA, (comida_x, comida_y, lado_quadrado, lado_quadrado))

        # Desenha Cobra
        for pedaco in corpo_cobra:
            pygame.draw.rect(tela, COR_COBRA_CORPO, (pedaco[0], pedaco[1], lado_quadrado, lado_quadrado))
            # Borda do pedaço da cobra
            pygame.draw.rect(tela, COR_COBRA_BORDA, (pedaco[0], pedaco[1], lado_quadrado, lado_quadrado), 1)
        
        desenhar_placar(tela, tamanho_cobra)
        pygame.display.flip()
        relogio.tick(fps)

    pygame.quit()
