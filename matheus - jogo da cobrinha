import pygame
import random

# --- CONFIGURAÇÕES ---
lagura_tela = 800
altura_tela = 500  # Alterado para 500 conforme solicitado
lado_quadrado = 20
fps = 10

# Novas Cores (Hexadecimal)
COR_FUNDO = "#1A1A1D"       # Um cinza quase preto
COR_COBRA_CORPO = "#3498DB" # Azul vibrante
COR_COBRA_BORDA = "#2980B9" # Azul escuro para a borda
COR_COMIDA = "#F1C40F"      # Amarelo

rodando = True
xq = lagura_tela // 2
yq = altura_tela // 2
move_x = 0
move_y = 0 

corpo_cobra = [] 
tamanho_cobra = 1

def gerar_comida():
    x = random.randrange(0, lagura_tela - lado_quadrado, lado_quadrado)
    y = random.randrange(0, altura_tela - lado_quadrado, lado_quadrado)
    return x, y 

comida_x, comida_y = gerar_comida()

def reiniciar():
    global xq, yq, move_x, move_y, corpo_cobra, tamanho_cobra, comida_x, comida_y
    xq, yq = lagura_tela // 2, altura_tela // 2
    move_x, move_y = 0, 0
    corpo_cobra = []
    tamanho_cobra = 1
    comida_x, comida_y = gerar_comida()

def proc_eventos():
    global rodando, move_x, move_y
    for evento in pygame.event.get():
        if evento.type == pygame.QUIT:
            rodando = False

        if evento.type == pygame.KEYDOWN:
            if evento.key == pygame.K_UP and move_y == 0:
                move_x = 0
                move_y = -lado_quadrado
            if evento.key == pygame.K_DOWN and move_y == 0:
                move_x = 0
                move_y = lado_quadrado
            if evento.key == pygame.K_LEFT and move_x == 0:
                move_y = 0
                move_x = -lado_quadrado
            if evento.key == pygame.K_RIGHT and move_x == 0:
                move_y = 0
                move_x = lado_quadrado
            if evento.key == pygame.K_ESCAPE:
                rodando = False
